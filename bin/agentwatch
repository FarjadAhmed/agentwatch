#!/usr/bin/env node
// agentwatch CLI — View what AI agents did on your machine

const fs = require('fs');
const path = require('path');
const os = require('os');

const { assessRisk } = require(path.join(__dirname, '..', 'src', 'risk'));
const { SESSIONS_DIR, buildIndex: _buildIndex } = require(path.join(__dirname, '..', 'src', 'sessions'));
const { analyzeRange, sessionAnomalies, formatDuration, durationMs, exportSession, projectName } = require(path.join(__dirname, '..', 'src', 'analytics'));
const { getSessionCost, formatTokens } = require(path.join(__dirname, '..', 'src', 'cost'));
const AGENTWATCH_DIR = path.join(os.homedir(), '.agentwatch');

const args = process.argv.slice(2);
const command = args[0] || 'help';

const COLORS = {
  reset: '\x1b[0m',
  bold: '\x1b[1m',
  dim: '\x1b[2m',
  red: '\x1b[31m',
  green: '\x1b[32m',
  yellow: '\x1b[33m',
  blue: '\x1b[34m',
  magenta: '\x1b[35m',
  cyan: '\x1b[36m',
  white: '\x1b[37m',
  bgRed: '\x1b[41m',
  bgYellow: '\x1b[43m',
  bgCyan: '\x1b[46m',
};

const c = (color, text) => `${COLORS[color]}${text}${COLORS.reset}`;

switch (command) {
  case 'sessions':
  case 'ls':
    listSessions(args.includes('--all'));
    break;
  case 'show':
  case 'view':
    showSession(args[1]);
    break;
  case 'last':
    showSession('last');
    break;
  case 'live':
    liveFollow(args[1]);
    break;
  case 'dash':
  case 'ui':
    require(path.join(__dirname, '..', 'src', 'dashboard.js'));
    break;
  case 'stats':
    showStats();
    break;
  case 'report':
    showReport(args[1]);
    break;
  case 'hotspots':
    showHotspots(args[1]);
    break;
  case 'export': {
    const exportArgs = args.slice(1).filter(a => !a.startsWith('--'));
    const format = args.includes('--json') ? 'json' : 'md';
    doExport(exportArgs[0], format);
    break;
  }
  case 'files':
    showFiles(args[1]);
    break;
  case 'commands':
    showCommands(args[1]);
    break;
  case 'danger':
    showDangerousActions(args[1]);
    break;
  case 'tokens':
    showTokens(args[1]);
    break;
  case 'status':
    showStatus();
    break;
  case 'prune':
    pruneOldSessions(args[1]);
    break;
  case 'install':
    install();
    break;
  case 'uninstall':
    uninstall();
    break;
  case 'help':
  default:
    showHelp();
    break;
}

// ─── Commands ───

function showHelp() {
  console.log(`
${c('bold', 'agentwatch')} — See what AI agents do on your machine

${c('bold', 'USAGE')}
  agentwatch ${c('cyan', '<command>')} [options]

${c('bold', 'SESSION REVIEW')}
  ${c('cyan', 'last')}              Show the most recent session
  ${c('cyan', 'show')} <id>         Show detailed timeline for a session
  ${c('cyan', 'sessions')}          List all recorded sessions (--all for full list)
  ${c('cyan', 'live')} [id]         Live-follow a session (default: latest)
  ${c('cyan', 'commands')} [id]     Show all bash commands run
  ${c('cyan', 'files')} [id]        Show all files touched
  ${c('cyan', 'danger')} [id]       Highlight potentially dangerous actions
  ${c('cyan', 'export')} [id]       Export session as markdown (--json for JSON)
  ${c('cyan', 'tokens')} [id]       Token usage breakdown for a session

${c('bold', 'ANALYTICS')}
  ${c('cyan', 'report')} [period]   Weekly report with project breakdown, hotspots, patterns
                    Period: week (default), month, or number of days
  ${c('cyan', 'hotspots')} [n]      Top N files AI modifies most across all sessions
  ${c('cyan', 'stats')}             Aggregate stats with per-project breakdown

${c('bold', 'MANAGEMENT')}
  ${c('cyan', 'dash')}              Open web dashboard in browser
  ${c('cyan', 'status')}            Check if agentwatch is installed and working
  ${c('cyan', 'prune')} [days]      Delete sessions older than N days (default: 30)
  ${c('cyan', 'install')}           Add agentwatch hooks to Claude Code
  ${c('cyan', 'uninstall')}         Remove agentwatch hooks from Claude Code

${c('bold', 'EXAMPLES')}
  agentwatch last                    # What just happened?
  agentwatch report                  # Weekly summary across all projects
  agentwatch report month            # Monthly summary
  agentwatch hotspots 10             # Top 10 most-modified files
  agentwatch export --json > out.json # Export latest session as JSON
  agentwatch danger                  # Flag risky actions
`);
}

function listSessions(showAll) {
  const index = loadIndex();
  const sessions = Object.entries(index).sort((a, b) =>
    new Date(b[1].started) - new Date(a[1].started)
  );

  if (sessions.length === 0) {
    console.log(c('dim', 'No sessions recorded yet. Run `agentwatch install` to get started.'));
    return;
  }

  const limit = showAll ? sessions.length : 20;
  const showing = sessions.slice(0, limit);

  console.log(`\n${c('bold', 'Recorded Sessions')} (${sessions.length} total)\n`);

  let lastDateLabel = '';
  for (const [id, s] of showing) {
    const dateLabel = dateBucket(s.started);
    if (dateLabel !== lastDateLabel) {
      lastDateLabel = dateLabel;
      console.log(`  ${c('bold', dateLabel)}`);
      console.log(c('dim', '  ──────────────────────────────────────────────────────────────────────'));
    }
    const shortId = id.substring(0, 8);
    const time = s.started ? new Date(s.started).toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' }) : '??:??';
    const dur = formatDuration(durationMs(s)).padEnd(5);
    const tools = String(s.tool_count).padStart(4);
    const cmds = String(s.commands_run).padStart(3);
    const project = getProjectName(s.cwd);
    const riskStr = s.risk_count > 0 ? c('red', ` ${s.risk_count} risks`) : '';
    console.log(`    ${c('cyan', shortId)}  ${c('dim', time)}  ${c('dim', dur)}  ${tools} actions  ${c('white', project)}${riskStr}`);
  }

  if (!showAll && sessions.length > limit) {
    console.log(c('dim', `\n  ... ${sessions.length - limit} older sessions hidden. Use ${c('cyan', 'agentwatch sessions --all')} to show all.`));
  }
  console.log();
}

function dateBucket(iso) {
  if (!iso) return 'Unknown';
  const d = new Date(iso);
  const now = new Date();
  const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
  const sessionDay = new Date(d.getFullYear(), d.getMonth(), d.getDate());
  const diffDays = Math.round((today - sessionDay) / 86400000);
  if (diffDays === 0) return 'Today';
  if (diffDays === 1) return 'Yesterday';
  if (diffDays < 7) return d.toLocaleDateString('en-US', { weekday: 'long' });
  return d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
}

function getProjectName(cwd) {
  if (!cwd) return '(unknown)';
  const parts = cwd.replace(/\/+$/, '').split('/');
  return parts[parts.length - 1] || cwd;
}

function showSession(idOrLast) {
  const { id, entries, meta } = resolveSession(idOrLast);
  if (!entries) return;

  const dur = entries.length > 0
    ? durationMs({ started: meta.started, last_activity: entries[entries.length - 1].timestamp })
    : 0;

  console.log(`\n${c('bold', 'Session')} ${c('cyan', id.substring(0, 10))}`);
  console.log(`${c('dim', 'Started:')}  ${formatTime(meta.started)}`);
  console.log(`${c('dim', 'Duration:')} ${formatDuration(dur)}`);
  console.log(`${c('dim', 'Dir:')}      ${meta.cwd || '(unknown)'}`);
  console.log(`${c('dim', 'Model:')}    ${meta.model || 'unknown'}`);
  console.log(`${c('dim', 'Actions:')}  ${entries.length}`);

  console.log();

  // Quick risk summary at top
  const allRisks = entries.flatMap(e => assessRisk(e)).filter(r => r.level !== 'info');
  if (allRisks.length > 0) {
    const crits = allRisks.filter(r => r.level === 'critical').length;
    const warns = allRisks.filter(r => r.level === 'warning').length;
    let riskLine = '';
    if (crits > 0) riskLine += c('red', `${crits} critical`);
    if (crits > 0 && warns > 0) riskLine += ', ';
    if (warns > 0) riskLine += c('yellow', `${warns} warning${warns > 1 ? 's' : ''}`);
    console.log(`${c('bgRed', ' RISKS ')} ${riskLine}\n`);
  }

  // Bash pass/fail summary
  const bashEntries = entries.filter(e => e.tool === 'Bash');
  if (bashEntries.length > 0) {
    const withExitCode = bashEntries.filter(e => e.exit_code !== null && e.exit_code !== undefined);
    const passed = withExitCode.filter(e => e.exit_code === 0).length;
    const failed = withExitCode.filter(e => e.exit_code !== 0).length;
    if (withExitCode.length > 0) {
      const passRate = Math.round((passed / withExitCode.length) * 100);
      const passColor = passRate >= 80 ? 'green' : passRate >= 50 ? 'yellow' : 'red';
      console.log(`${c('dim', 'Bash:')}     ${bashEntries.length} commands, ${c(passColor, `${passRate}% passed`)}${failed > 0 ? c('red', `, ${failed} failed`) : ''}\n`);
    } else {
      console.log(`${c('dim', 'Bash:')}     ${bashEntries.length} commands\n`);
    }
  }

  console.log(c('bold', 'Timeline'));
  console.log(c('dim', '────────'));

  for (const entry of entries) {
    const time = formatTimeShort(entry.timestamp);
    const icon = toolIcon(entry.tool);
    const desc = formatEntry(entry);
    console.log(`  ${c('dim', time)}  ${icon}  ${desc}`);
  }
  console.log();
}

function showCommands(idOrLast) {
  const { entries } = resolveSession(idOrLast || 'last');
  if (!entries) return;

  const cmds = entries.filter(e => e.tool === 'Bash');
  const withExitCode = cmds.filter(e => e.exit_code !== null && e.exit_code !== undefined);
  const passed = withExitCode.filter(e => e.exit_code === 0).length;
  const failed = withExitCode.filter(e => e.exit_code !== 0).length;

  let header = `\n${c('bold', 'Bash Commands')} (${cmds.length} total`;
  if (withExitCode.length > 0) header += `, ${c('green', `${passed} passed`)}, ${c('red', `${failed} failed`)}`;
  header += ')\n';
  console.log(header);

  for (const entry of cmds) {
    const time = formatTimeShort(entry.timestamp);
    const exitColor = entry.exit_code === 0 ? 'green' : entry.exit_code ? 'red' : 'dim';
    const exitStr = entry.exit_code !== null ? c(exitColor, `[${entry.exit_code}]`) : '';
    console.log(`  ${c('dim', time)}  ${exitStr} ${c('white', entry.command || '(empty)')}`);
  }
  console.log();
}

function showFiles(idOrLast) {
  const { entries } = resolveSession(idOrLast || 'last');
  if (!entries) return;

  const fileActions = entries.filter(e => e.file);
  const fileMap = {};

  for (const e of fileActions) {
    if (!fileMap[e.file]) fileMap[e.file] = [];
    fileMap[e.file].push(e.tool);
  }

  console.log(`\n${c('bold', 'Files Touched')} (${Object.keys(fileMap).length} unique)\n`);

  for (const [file, actions] of Object.entries(fileMap)) {
    const actionStr = [...new Set(actions)].map(a => {
      switch (a) {
        case 'Read': return c('blue', 'R');
        case 'Write': return c('red', 'W');
        case 'Edit': return c('yellow', 'E');
        default: return c('dim', a[0]);
      }
    }).join('');
    console.log(`  [${actionStr}] ${shortenPath(file)}`);
  }

  console.log(`\n  ${c('dim', 'Legend:')} ${c('blue', 'R')}ead ${c('yellow', 'E')}dit ${c('red', 'W')}rite\n`);
}

function showDangerousActions(idOrLast) {
  const { entries } = resolveSession(idOrLast || 'last');
  if (!entries) return;

  const dangerous = [];

  for (const entry of entries) {
    const risks = assessRisk(entry);
    if (risks.length > 0) {
      dangerous.push({ entry, risks });
    }
  }

  if (dangerous.length === 0) {
    console.log(`\n${c('green', 'No potentially dangerous actions detected.')}\n`);
    return;
  }

  console.log(`\n${c('bgRed', ' DANGER ')} ${c('bold', `${dangerous.length} potentially risky actions found`)}\n`);

  for (const { entry, risks } of dangerous) {
    const time = formatTimeShort(entry.timestamp);
    const icon = toolIcon(entry.tool);
    console.log(`  ${c('dim', time)}  ${icon}  ${formatEntry(entry)}`);
    for (const risk of risks) {
      const levelColor = risk.level === 'critical' ? 'red' : risk.level === 'warning' ? 'yellow' : 'cyan';
      console.log(`           ${c(levelColor, `[${risk.level}]`)} ${risk.msg}`);
    }
    console.log();
  }
}

function showTokens(idOrLast) {
  const { id, meta } = resolveSession(idOrLast || 'last');
  if (!id) return;

  const costInfo = getSessionCost(id, meta.cwd);
  if (!costInfo) {
    console.log(`\n${c('dim', 'No token data found for this session.')}`);
    console.log(c('dim', 'Token data is read from Claude Code\'s logs in ~/.claude/projects/'));
    console.log(c('dim', 'It may not be available for older sessions.\n'));
    return;
  }

  const t = costInfo.tokens;
  console.log(`\n${c('bold', 'Token Usage')} — session ${c('cyan', id.substring(0, 10))}\n`);
  console.log(`  Model:          ${c('white', costInfo.model || 'unknown')}`);
  console.log(`  Messages:       ${c('cyan', costInfo.messageCount)}`);
  console.log();

  console.log(`  ${c('bold', 'Tokens')}`);
  console.log(`  ──────`);
  console.log(`    Input:         ${c('cyan', formatTokens(t.input).padStart(8))}`);
  console.log(`    Output:        ${c('yellow', formatTokens(t.output).padStart(8))}`);
  console.log(`    Cache write:   ${c('magenta', formatTokens(t.cacheWrite).padStart(8))}`);
  console.log(`    Cache read:    ${c('green', formatTokens(t.cacheRead).padStart(8))}`);
  console.log(`    ${'─'.repeat(28)}`);
  console.log(`    Total:         ${c('white', formatTokens(costInfo.totalTokens).padStart(8))}`);

  if (t.cacheRead > 0 || t.cacheWrite > 0) {
    const cacheRatio = t.cacheRead / (t.input + t.cacheRead + t.cacheWrite || 1);
    console.log(`\n    Cache hit rate: ${c('cyan', `${Math.round(cacheRatio * 100)}%`)}`);
  }

  console.log(`\n  ${c('dim', 'Note: token counts are read from Claude Code\'s internal logs')}`);
  console.log(`  ${c('dim', 'and may not reflect actual billing. Use your Anthropic dashboard')}`);
  console.log(`  ${c('dim', 'for accurate usage and cost data.')}`);
  console.log();
}

function showStats() {
  const index = loadIndex();
  const sessions = Object.entries(index).sort((a, b) =>
    new Date(b[1].started) - new Date(a[1].started)
  );

  if (sessions.length === 0) {
    console.log(c('dim', 'No sessions recorded yet.'));
    return;
  }

  let totalTools = 0;
  let totalCmds = 0;
  let totalFiles = new Set();
  let totalDur = 0;
  let toolBreakdown = {};
  let projectMap = {};

  for (const [id, s] of sessions) {
    totalTools += s.tool_count;
    totalCmds += s.commands_run;
    totalDur += durationMs(s);
    s.files_touched.forEach(f => totalFiles.add(f));
    for (const [tool, count] of Object.entries(s.tools_used)) {
      toolBreakdown[tool] = (toolBreakdown[tool] || 0) + count;
    }
    const project = projectName(s.cwd);
    if (!projectMap[project]) projectMap[project] = { sessions: 0, actions: 0, duration: 0 };
    projectMap[project].sessions++;
    projectMap[project].actions += s.tool_count;
    projectMap[project].duration += durationMs(s);
  }

  const avgDur = sessions.length > 0 ? totalDur / sessions.length : 0;

  console.log(`\n${c('bold', 'Aggregate Stats')}\n`);
  console.log(`  Sessions:        ${c('cyan', sessions.length)}`);
  console.log(`  Total time:      ${c('cyan', formatDuration(totalDur))} (avg ${formatDuration(avgDur)}/session)`);
  console.log(`  Total actions:   ${c('cyan', totalTools)}`);
  console.log(`  Bash commands:   ${c('yellow', totalCmds)}`);
  console.log(`  Unique files:    ${c('green', totalFiles.size)}`);

  // Per-project breakdown
  const projectList = Object.entries(projectMap)
    .sort((a, b) => b[1].sessions - a[1].sessions);

  if (projectList.length > 1) {
    console.log(`\n  ${c('bold', 'Per project:')}`);
    for (const [name, stats] of projectList) {
      const sessStr = String(stats.sessions).padStart(3);
      const actStr = String(stats.actions).padStart(5);
      const durStr = formatDuration(stats.duration).padStart(6);
      console.log(`    ${c('white', name.padEnd(20))} ${sessStr} sessions  ${actStr} actions  ${durStr}`);
    }
  }

  // Tool breakdown
  console.log(`\n  ${c('bold', 'Tool breakdown:')}`);
  const sorted = Object.entries(toolBreakdown).sort((a, b) => b[1] - a[1]);
  for (const [tool, count] of sorted) {
    const bar = '█'.repeat(Math.min(40, Math.round(count / totalTools * 40)));
    console.log(`    ${tool.padEnd(12)} ${String(count).padStart(5)}  ${c('cyan', bar)}`);
  }
  console.log();
}

function showReport(periodArg) {
  const index = loadIndex();
  if (Object.keys(index).length === 0) {
    console.log(c('dim', 'No sessions recorded yet.'));
    return;
  }

  let days = 7;
  let periodLabel = 'Weekly';
  if (periodArg === 'month') { days = 30; periodLabel = 'Monthly'; }
  else if (periodArg && !isNaN(parseInt(periodArg, 10))) { days = parseInt(periodArg, 10); periodLabel = `${days}-day`; }

  const endMs = Date.now();
  const startMs = endMs - days * 86400000;
  const startDate = new Date(startMs);
  const endDate = new Date(endMs);
  const dateRange = `${fmtDate(startDate)} — ${fmtDate(endDate)}`;

  const report = analyzeRange(SESSIONS_DIR, index, startMs, endMs);

  if (report.sessionCount === 0) {
    console.log(`\n${c('dim', `No sessions in the last ${days} days.`)}\n`);
    return;
  }

  const avgDur = report.sessionCount > 0 ? report.totalDuration / report.sessionCount : 0;

  console.log(`\n${c('bold', `${periodLabel} Report`)} ${c('dim', dateRange)}`);
  console.log(c('dim', '━'.repeat(60)));

  // Overview
  console.log(`\n  ${c('cyan', report.sessionCount)} sessions across ${c('cyan', report.projects.length)} project${report.projects.length !== 1 ? 's' : ''}`);
  console.log(`  ${c('cyan', formatDuration(report.totalDuration))} total (avg ${formatDuration(avgDur)}/session)`);
  console.log(`  ${c('cyan', report.totalActions)} actions, ${c('yellow', report.totalBashCmds)} bash commands`);

  if (report.totalBashCmds > 0 && report.bashPassRate !== null) {
    const passColor = report.bashPassRate >= 80 ? 'green' : report.bashPassRate >= 50 ? 'yellow' : 'red';
    console.log(`  Bash pass rate: ${c(passColor, `${report.bashPassRate}%`)} (${c('red', report.totalBashFails)} failed)`);
  }

  if (report.totalCriticals > 0 || report.totalWarnings > 0) {
    let riskLine = '  Risks: ';
    if (report.totalCriticals > 0) riskLine += c('red', `${report.totalCriticals} critical`);
    if (report.totalCriticals > 0 && report.totalWarnings > 0) riskLine += ', ';
    if (report.totalWarnings > 0) riskLine += c('yellow', `${report.totalWarnings} warnings`);
    console.log(riskLine);
  }

  // Per-project breakdown
  if (report.projects.length > 0) {
    console.log(`\n${c('bold', '  Projects')}`);
    console.log(c('dim', '  ────────'));
    for (const p of report.projects) {
      const durStr = formatDuration(p.duration).padStart(6);
      const actStr = String(p.actions).padStart(5);
      console.log(`    ${c('white', p.name.padEnd(22))} ${p.sessions} session${p.sessions !== 1 ? 's' : ' '}  ${durStr}  ${actStr} actions`);
    }
  }

  // File hotspots
  const topFiles = report.hotspots.slice(0, 10);
  if (topFiles.length > 0) {
    console.log(`\n${c('bold', '  File Hotspots')} ${c('dim', '(most modified)')}`);
    console.log(c('dim', '  ──────────────'));
    for (const h of topFiles) {
      const mods = String(h.modifications).padStart(3);
      const sessCount = String(h.sessions).padStart(2);
      console.log(`    ${c('yellow', mods)} edits  ${c('dim', sessCount)} sessions  ${shortenPath(h.file)}`);
    }
  }

  // Command patterns
  const topCmds = report.commands.slice(0, 10);
  if (topCmds.length > 0) {
    console.log(`\n${c('bold', '  Command Patterns')} ${c('dim', '(most frequent)')}`);
    console.log(c('dim', '  ─────────────────'));
    for (const cmd of topCmds) {
      const countStr = String(cmd.count).padStart(4);
      const passStr = cmd.passRate !== null ? `  ${c(cmd.passRate >= 80 ? 'green' : cmd.passRate >= 50 ? 'yellow' : 'red', `${String(cmd.passRate).padStart(3)}%`)}` : '      ';
      console.log(`    ${c('cyan', countStr)}x${passStr}  ${c('white', truncate(cmd.command, 55))}`);
    }
  }

  console.log();
}

function showHotspots(nArg) {
  const n = parseInt(nArg, 10) || 15;
  const index = loadIndex();
  if (Object.keys(index).length === 0) {
    console.log(c('dim', 'No sessions recorded yet.'));
    return;
  }

  const report = analyzeRange(SESSIONS_DIR, index, 0, Date.now());

  if (report.hotspots.length === 0) {
    console.log(`\n${c('dim', 'No file modifications recorded.')}\n`);
    return;
  }

  const top = report.hotspots.slice(0, n);

  console.log(`\n${c('bold', 'File Hotspots')} — files AI modifies most across all sessions\n`);

  const maxMods = top[0].modifications;
  for (const h of top) {
    const mods = String(h.modifications).padStart(3);
    const bar = '█'.repeat(Math.max(1, Math.round(h.modifications / maxMods * 20)));
    const sessCount = String(h.sessions).padStart(2);
    console.log(`  ${c('yellow', mods)} edits  ${c('dim', sessCount)} sessions  ${c('cyan', bar)}  ${shortenPath(h.file)}`);
  }

  console.log(`\n  ${c('dim', 'Files modified most often may indicate complexity, fragility, or active development.')}\n`);
}

function doExport(idOrLast, format) {
  const { id, meta } = resolveSession(idOrLast || 'last');
  if (!id) return;

  const index = loadIndex();
  const sessionMeta = index[id] || meta;
  const output = exportSession(SESSIONS_DIR, id, sessionMeta, format);

  if (!output) {
    console.error(c('red', 'Failed to export session.'));
    process.exit(1);
  }

  // If stdout is a TTY, print with a header. Otherwise just output raw (for piping).
  if (process.stdout.isTTY) {
    console.log(c('dim', `Exported session ${id.substring(0, 10)} as ${format === 'json' ? 'JSON' : 'Markdown'}:\n`));
  }
  process.stdout.write(output);
}

function liveFollow(idOrLast) {
  const { id, logPath } = resolveSession(idOrLast || 'last', true);
  if (!logPath) return;

  console.log(`\n${c('bold', 'Live following session')} ${c('cyan', id.substring(0, 10))}`);
  console.log(c('dim', 'Press Ctrl+C to stop\n'));

  let lastSize = 0;
  try {
    const stat = fs.statSync(logPath);
    lastSize = stat.size;
    // Print existing entries first
    const existing = fs.readFileSync(logPath, 'utf8').trim();
    if (existing) {
      for (const line of existing.split('\n')) {
        try {
          const entry = JSON.parse(line);
          if (entry.type === 'session_start') continue;
          const time = formatTimeShort(entry.timestamp);
          const icon = toolIcon(entry.tool);
          console.log(`  ${c('dim', time)}  ${icon}  ${formatEntry(entry)}`);
        } catch (e) {}
      }
    }
  } catch (e) {}

  // Watch for new entries
  const interval = setInterval(() => {
    try {
      const stat = fs.statSync(logPath);
      if (stat.size > lastSize) {
        const fd = fs.openSync(logPath, 'r');
        const buf = Buffer.alloc(stat.size - lastSize);
        fs.readSync(fd, buf, 0, buf.length, lastSize);
        fs.closeSync(fd);
        lastSize = stat.size;

        const lines = buf.toString().trim().split('\n');
        for (const line of lines) {
          try {
            const entry = JSON.parse(line);
            if (entry.type === 'session_start') continue;
            const time = formatTimeShort(entry.timestamp);
            const icon = toolIcon(entry.tool);
            console.log(`  ${c('dim', time)}  ${icon}  ${formatEntry(entry)}`);
          } catch (e) {}
        }
      }
    } catch (e) {}
  }, 500);

  process.on('SIGINT', () => {
    clearInterval(interval);
    console.log(c('dim', '\nStopped.'));
    process.exit(0);
  });
}

function showStatus() {
  console.log(`\n${c('bold', 'agentwatch status')}\n`);

  // Check hooks installed
  const settingsPath = path.join(os.homedir(), '.claude', 'settings.json');
  let hooksInstalled = false;
  try {
    const settings = JSON.parse(fs.readFileSync(settingsPath, 'utf8'));
    hooksInstalled = ['PostToolUse', 'SessionStart', 'Stop'].every(event =>
      settings.hooks?.[event]?.some(h => h.hooks?.some(hh => hh.command?.includes('agentwatch')))
    );
  } catch (e) {}

  const hookStatus = hooksInstalled
    ? c('green', 'installed')
    : c('red', 'not installed') + c('dim', ' — run ') + c('cyan', 'agentwatch install');
  console.log(`  Hooks:      ${hookStatus}`);

  // Check log directory
  const sessionsDir = path.join(os.homedir(), '.agentwatch', 'sessions');
  let sessionCount = 0;
  let totalSize = 0;
  try {
    const files = fs.readdirSync(sessionsDir).filter(f => f.endsWith('.jsonl'));
    sessionCount = files.length;
    for (const f of files) {
      totalSize += fs.statSync(path.join(sessionsDir, f)).size;
    }
  } catch (e) {}

  console.log(`  Sessions:   ${c('cyan', sessionCount)} recorded`);
  console.log(`  Log size:   ${c('cyan', formatBytes(totalSize))}`);
  console.log(`  Log path:   ${c('dim', '~/.agentwatch/sessions/')}`);

  // Check index
  const index = loadIndex();
  const lastSession = Object.values(index).sort((a, b) =>
    new Date(b.started) - new Date(a.started)
  )[0];

  if (lastSession) {
    console.log(`  Last active: ${c('dim', formatTime(lastSession.last_activity || lastSession.started))}`);
  }

  console.log();

  if (hooksInstalled && sessionCount > 0) {
    console.log(`  ${c('green', 'Everything looks good.')} agentwatch is logging your Claude Code sessions.`);
  } else if (hooksInstalled) {
    console.log(`  ${c('yellow', 'Hooks installed but no sessions yet.')} Start a Claude Code session to begin logging.`);
  } else {
    console.log(`  ${c('yellow', 'Not yet set up.')} Run ${c('cyan', 'agentwatch install')} to get started.`);
  }
  console.log();
}

function pruneOldSessions(daysArg) {
  const days = parseInt(daysArg, 10) || 30;
  const cutoff = Date.now() - days * 86400000;

  let files;
  try {
    files = fs.readdirSync(SESSIONS_DIR).filter(f => f.endsWith('.jsonl'));
  } catch (e) {
    console.log(c('dim', 'No sessions directory found.'));
    return;
  }

  const toDelete = [];
  for (const file of files) {
    const filePath = path.join(SESSIONS_DIR, file);
    try {
      const stat = fs.statSync(filePath);
      if (stat.mtimeMs < cutoff) {
        toDelete.push({ file, path: filePath, size: stat.size });
      }
    } catch (e) {}
  }

  if (toDelete.length === 0) {
    console.log(`\n${c('green', 'Nothing to prune.')} No sessions older than ${days} days.\n`);
    return;
  }

  const totalSize = toDelete.reduce((s, f) => s + f.size, 0);
  console.log(`\n${c('bold', 'Pruning sessions older than ' + days + ' days')}\n`);
  console.log(`  ${c('yellow', toDelete.length)} sessions to delete (${formatBytes(totalSize)})`);

  for (const f of toDelete) {
    fs.unlinkSync(f.path);
  }

  console.log(`  ${c('green', 'Deleted ' + toDelete.length + ' session logs.')}`);
  console.log(`  ${c('dim', 'Freed ' + formatBytes(totalSize))}\n`);
}

function install() {
  const claudeDir = path.join(os.homedir(), '.claude');
  const settingsPath = path.join(claudeDir, 'settings.json');
  let settings = {};
  try {
    settings = JSON.parse(fs.readFileSync(settingsPath, 'utf8'));
  } catch (e) {
    // If no settings.json exists, create one
    if (!fs.existsSync(claudeDir)) {
      console.log(c('red', 'Claude Code config directory not found (~/.claude/).'));
      console.log(c('dim', 'Make sure Claude Code is installed first.'));
      process.exit(1);
    }
    settings = {};
  }

  if (!settings.hooks) settings.hooks = {};

  const hookDir = path.resolve(__dirname, '..', 'src');
  const postToolCmd = `node "${path.join(hookDir, 'hook.js')}"`;
  const sessionStartCmd = `node "${path.join(hookDir, 'session-start-hook.js')}"`;
  const stopCmd = `node "${path.join(hookDir, 'stop-hook.js')}"`;

  const hookDefs = [
    { event: 'PostToolUse', command: postToolCmd },
    { event: 'SessionStart', command: sessionStartCmd },
    { event: 'Stop', command: stopCmd },
  ];

  for (const { event, command } of hookDefs) {
    if (!settings.hooks[event]) settings.hooks[event] = [];
    const idx = settings.hooks[event].findIndex(h =>
      h.hooks?.some(hh => hh.command?.includes('agentwatch'))
    );
    const entry = { hooks: [{ type: 'command', command }] };
    if (idx >= 0) {
      settings.hooks[event][idx] = entry;
    } else {
      settings.hooks[event].push(entry);
    }
  }

  fs.writeFileSync(settingsPath, JSON.stringify(settings, null, 2));
  console.log(`\n${c('green', 'agentwatch installed successfully!')}`);
  console.log(`${c('dim', 'Hooks added to')} ${settingsPath}`);
  console.log(`${c('dim', 'Logs will appear in')} ~/.agentwatch/sessions/`);
  console.log(`\n${c('dim', 'Run')} ${c('cyan', 'agentwatch last')} ${c('dim', 'after a Claude Code session to review.')}\n`);
}

function uninstall() {
  const settingsPath = path.join(os.homedir(), '.claude', 'settings.json');
  let settings = {};
  try {
    settings = JSON.parse(fs.readFileSync(settingsPath, 'utf8'));
  } catch (e) {
    console.log(c('red', `Cannot read ${settingsPath}`));
    process.exit(1);
  }

  if (settings.hooks) {
    for (const event of ['PostToolUse', 'SessionStart', 'Stop']) {
      if (settings.hooks[event]) {
        settings.hooks[event] = settings.hooks[event].filter(h =>
          !h.hooks?.some(hh => hh.command?.includes('agentwatch'))
        );
        if (settings.hooks[event].length === 0) delete settings.hooks[event];
      }
    }
  }

  fs.writeFileSync(settingsPath, JSON.stringify(settings, null, 2));
  console.log(`\n${c('green', 'agentwatch uninstalled.')} Hooks removed from settings.json`);
  console.log(`${c('dim', 'Session logs preserved in')} ~/.agentwatch/\n`);
}

// ─── Helpers ───

function loadIndex() {
  return _buildIndex();
}

function resolveSession(idOrLast, returnPath = false) {
  const index = loadIndex();
  const sessions = Object.entries(index).sort((a, b) =>
    new Date(b[1].started) - new Date(a[1].started)
  );

  if (sessions.length === 0) {
    console.log(c('dim', 'No sessions recorded yet.'));
    return {};
  }

  let id;
  if (!idOrLast || idOrLast === 'last') {
    id = sessions[0][0];
  } else {
    // Match by prefix
    const match = sessions.find(([sid]) => sid.startsWith(idOrLast));
    if (!match) {
      console.log(c('red', `No session matching "${idOrLast}"`));
      return {};
    }
    id = match[0];
  }

  const logPath = path.join(SESSIONS_DIR, `${id}.jsonl`);
  if (returnPath) return { id, logPath };

  try {
    const lines = fs.readFileSync(logPath, 'utf8').trim().split('\n');
    const parsed = lines.filter(Boolean).map(l => JSON.parse(l));
    const meta = {};
    const startEntry = parsed.find(e => e.type === 'session_start');
    if (startEntry) {
      meta.started = startEntry.timestamp;
      meta.cwd = startEntry.cwd;
      meta.model = startEntry.model;
    }
    const entries = parsed.filter(e => e.type !== 'session_start');
    if (!meta.started && entries.length > 0) meta.started = entries[0].timestamp;
    return { id, entries, meta, logPath };
  } catch (e) {
    console.log(c('dim', `No log file for session ${id.substring(0, 10)}`));
    return {};
  }
}

function toolIcon(tool) {
  const icons = {
    Bash: c('yellow', 'SH '),
    Write: c('red', 'WRT'),
    Edit: c('magenta', 'EDT'),
    Read: c('blue', 'RD '),
    Glob: c('cyan', 'GLB'),
    Grep: c('cyan', 'GRP'),
    WebFetch: c('green', 'WEB'),
    Agent: c('white', 'AGT'),
  };
  return icons[tool] || c('dim', tool?.substring(0, 3)?.padEnd(3) || '???');
}

function formatEntry(entry) {
  switch (entry.tool) {
    case 'Bash':
      const cmd = truncate(entry.command, 80) || '(empty)';
      return `${c('white', cmd)}`;
    case 'Write':
      return `${c('red', 'write')} ${shortenPath(entry.file)} ${c('dim', `(${formatBytes(entry.bytes)})`)}`;
    case 'Edit':
      return `${c('magenta', 'edit')} ${shortenPath(entry.file)}`;
    case 'Read':
      return `${c('blue', 'read')} ${shortenPath(entry.file)}`;
    case 'Glob':
      return `${c('cyan', 'glob')} ${entry.pattern}`;
    case 'Grep':
      return `${c('cyan', 'grep')} ${entry.pattern}`;
    case 'WebFetch':
      return `${c('green', 'fetch')} ${entry.url}`;
    case 'Agent':
      return `${c('white', 'agent')} ${entry.description || entry.subagent_type || ''}`;
    default:
      return `${entry.tool}`;
  }
}

function fmtDate(d) {
  return d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short' });
}

function formatTime(iso) {
  if (!iso) return '(unknown)'.padEnd(21);
  const d = new Date(iso);
  return d.toLocaleString('en-GB', {
    day: '2-digit', month: 'short', year: 'numeric',
    hour: '2-digit', minute: '2-digit',
  }).padEnd(21);
}

function formatTimeShort(iso) {
  if (!iso) return '??:??:??';
  const d = new Date(iso);
  return d.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
}

function formatBytes(bytes) {
  if (!bytes) return '0 B';
  if (bytes < 1024) return `${bytes} B`;
  if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;
  return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
}

function shortenPath(p) {
  if (!p) return '(unknown)';
  const home = os.homedir();
  if (p.startsWith(home)) return '~' + p.substring(home.length);
  return p;
}

function truncate(str, max) {
  if (!str) return null;
  if (str.length <= max) return str;
  return str.substring(0, max) + '...';
}
